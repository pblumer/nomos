# Nomos environment example
# Copy this file to deploy/.env and adjust values for your target environment.

# General
NOMOS_ENV=dev
NOMOS_DOMAIN=localhost
NOMOS_LOG_LEVEL=INFO
NOMOS_WORKSPACE_ROOT=/workspaces

# Backend runtime
NOMOS_API_HOST=0.0.0.0
NOMOS_API_PORT=8000
NOMOS_FRONTEND_ORIGIN=http://localhost:5173

# Catalog paths (can point to external checkout, e.g. ../nomos-catalog)
NOMOS_PRODUCTS_DIR=./catalog/products
NOMOS_REQUIREMENTS_DIR=./catalog/requirements
NOMOS_RULES_DIR=./catalog/rules

# Git integration
NOMOS_GIT_PROVIDER=github
NOMOS_GIT_REPO_URL=https://github.com/pblumer/nomos.git
NOMOS_GIT_DEFAULT_BRANCH=main
NOMOS_GIT_TOKEN=

# AI integration (optional)
NOMOS_AI_ENABLED=false
NOMOS_AI_PROVIDER=
NOMOS_AI_API_KEY=

# Container images for prod deploy
NOMOS_BACKEND_IMAGE=ghcr.io/pblumer/nomos-backend:latest
NOMOS_FRONTEND_IMAGE=ghcr.io/pblumer/nomos-frontend:latest

# Optional deploy helper defaults
NOMOS_IMAGE_REPO=ghcr.io/pblumer/nomos
NOMOS_HEALTHCHECK_URL=http://localhost/api/health
