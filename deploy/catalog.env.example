# Catalog pinning helper config
# Copy to deploy/catalog.env and adjust as needed.

# Source repo for business catalog artifacts
NOMOS_CATALOG_REPO=https://github.com/pblumer/nomos-catalog.git

# Local checkout location used by deploy/scripts/sync-catalog.sh
NOMOS_CATALOG_DIR=../nomos-catalog

# Pin runtime behavior to an immutable release tag or commit SHA
CATALOG_REF=catalog-v0.1.0
